# ── Required ────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
ANTHROPIC_API_KEY=sk-ant-xxx-or-sk-ant-oat-xxx

# ── Security (REQUIRED) ────────────────────────
# Comma-separated Telegram user IDs. Bot will REFUSE to start if empty.
# Use /myid command to find your ID.
ALLOWED_USERS=999808594

# ── Optional ────────────────────────────────────
MODEL=claude-sonnet-4-20250514
SYSTEM_PROMPT=You are a helpful coding assistant.
MAX_HISTORY=50

# Rate limit: max messages per user per minute
RATE_LIMIT_PER_MINUTE=10

# File access: comma-separated allowed directories
# Default: current working directory only
ALLOWED_PATHS=/Users/ming/projects,/Users/ming/.openclaw/workspace/tg-agent

# ACP (Claude Code) settings
ACP_DEFAULT_CWD=/Users/ming/projects
ACP_TIMEOUT_MS=180000
